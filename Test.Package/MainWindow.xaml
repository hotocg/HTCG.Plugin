<Window x:Class="Test.Package.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Test.Package"
        xmlns:p="http://schemas.htcgplugin/2025/xaml"
        mc:Ignorable="d"
        Title="Test Package" Height="500" Width="500"
        WindowStartupLocation="CenterScreen"
        >
    <Grid>
        <StackPanel>
            <!--<Button Content="Click me"
                    Click="Button_Click"
                    local:CommandBehavior.Command="{Binding TestCommand}"
                    CommandParameter="{Binding}"
                    />-->

            <Button Content="Test" Width="120" Height="40"
                    p:CommandBehavior.Event="Click"
                    p:CommandBehavior.Command="{Binding TestCommand}"
                    p:CommandBehavior.CommandParameter="Hello World"
                    />
            <Button Content="Async Test" Width="120" Height="40"
                    Command="{Binding AsyncTestCommand}"
                    CommandParameter="{Binding}"
                    />
            <TextBlock Text="{Binding Text}"/>
        </StackPanel>
    </Grid>
</Window>
